# PostgreSQL
POSTGRES_USER=hello_user
POSTGRES_PASSWORD=hello_pass
POSTGRES_DB=hello_db
POSTGRES_PORT=5432

# API Service
API_PORT=8000
API_HOST=0.0.0.0
DATABASE_URL=postgresql+asyncpg://hello_user:hello_pass@db:5432/hello_db
WEBSOCKET_URL=http://websocket:8001

# WebSocket Service
WS_PORT=8001
WS_HOST=0.0.0.0

# Frontend
FRONTEND_PORT=3000
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8001

# GitHub Container Registry
REGISTRY=ghcr.io
REGISTRY_USER=sefawer
IMAGE_TAG=latest